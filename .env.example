# === DeepSeek ===
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# === GigaChat (Сбер) ===
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=false

# === Выбор ИИ ===
# auto | deepseek | gigachat
LLM_PROVIDER=auto
# При auto: сначала gigachat, при ошибке — deepseek
LLM_PRIMARY=gigachat
LLM_FALLBACK=true

# === MySQL ===
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tour_generator

SITE_PRIMARY_URL=https://bon-voyage28.ru/
SITE_SECONDARY_URL=https://bonvoyage28.ru/
AGENCY_CONTACT_URL=https://bon-voyage28.ru/company/contacts
# Бюджет в $ конвертируется в рубли для поиска в БД
USD_TO_RUB=95


# === Авиабилеты (Travelpayouts) ===    
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_API_URL=https://api.travelpayouts.com
FLIGHTS_DEFAULT_ORIGIN=BQS
FLIGHTS_PROVIDER=all

# === Amadeus (второй источник авиабилетов) ===
# Создать приложение: https://developers.amadeus.com/
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
# test.api.amadeus.com (песочница) | api.amadeus.com (прод)
AMADEUS_API_URL=https://test.api.amadeus.com

# === Timeweb Cloud (production) ===
# Полная инструкция: timeweb/DEPLOY.md
# Шаблон для панели: timeweb/.env.production.example
#
# DB_HOST=xxxxx.twc1.net
# DB_PORT=3306
# DB_USER=gen_user
# DB_PASSWORD=пароль_из_панели
# DB_NAME=default_db
# DB_SKIP_CREATE=true
# DB_SSL_DISABLED=true
# Панель менеджера (логин по умолчанию: admin / bonvoyage)
ADMIN_DEFAULT_LOGIN=admin
ADMIN_DEFAULT_PASSWORD=bonvoyage
ADMIN_SECRET_KEY=change-this-secret-on-server
# PORT=8000
#
# App Platform:
#   Сборка: pip3 install --upgrade -r requirements.txt
#   Запуск: uvicorn main:app --host 0.0.0.0 --port 8000
#   Health: /health
