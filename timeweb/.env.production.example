# Скопируйте в timeweb/.env.production и заполните.
# В App Platform: «Переменные» → «Загрузить из файла» (.env)

# === MySQL (Timeweb Cloud → Базы данных → Подключение) ===
DB_HOST=ваш-id.twc1.net
DB_PORT=3306
DB_USER=gen_user
DB_PASSWORD=пароль_из_панели
DB_NAME=default_db
DB_SKIP_CREATE=true
DB_SSL_DISABLED=true

# === ИИ (хотя бы один ключ) ===
DEEPSEEK_API_KEY=sk-ваш-ключ
GIGACHAT_CREDENTIALS=
LLM_PROVIDER=auto
LLM_PRIMARY=gigachat
LLM_FALLBACK=true

# === Сайт турфирмы ===
SITE_PRIMARY_URL=https://bon-voyage28.ru/
SITE_SECONDARY_URL=https://bonvoyage28.ru/
AGENCY_CONTACT_URL=https://bon-voyage28.ru/company/contacts
USD_TO_RUB=95

# === Авиабилеты (опционально) ===
TRAVELPAYOUTS_TOKEN=
FLIGHTS_DEFAULT_ORIGIN=BQS
FLIGHTS_PROVIDER=all

# === Облако ===
PORT=8000
SEED_DEMO_ON_START=true
